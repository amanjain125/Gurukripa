# Optional: Google Maps embed (the Contact page uses an unauthenticated embed by default).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional: form provider endpoint (Resend, Formspree, etc.)
CONTACT_FORM_ENDPOINT=

# Site URL used for canonical + OG metadata
NEXT_PUBLIC_SITE_URL=https://gurukripaconstructions.com
